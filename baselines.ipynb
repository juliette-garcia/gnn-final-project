      "source": [
        "# Tabular baselines\n",
        "\n",
        "This mirrors the temporal GNN notebook (`lanl_temporal_host_risk.ipynb`): at each decision time we take every host that was active in the trailing **W**-second window, build features from that window only, and predict whether that host appears in any malicious auth in **(t, t+H]** (src or dst).\n",
        "\n",
        "Rows are **(host, decision time)** pairs—not individual auth lines. Train/val/test uses **time cutoffs** on the decision-time axis (60/20/20 of the span here); nothing gets shuffled across time.\n",
        "\n",
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "26035833",
      "metadata": {},
      "outputs": [],
      "source": [
        "from __future__ import annotations\n",
        "\n",
        "import json\n",
        "import os\n",
        "import time\n",
        "from dataclasses import dataclass, asdict\n",
        "from typing import Dict, List, Optional, Tuple\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.ensemble import HistGradientBoostingClassifier\n",
        "from sklearn.impute import SimpleImputer\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import (\n",
        "    average_precision_score,\n",
        "    confusion_matrix,\n",
        "    precision_recall_curve,\n",
        "    precision_recall_fscore_support,\n",
        "    roc_auc_score,\n",
        "    roc_curve,\n",
        ")\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "try:\n",
        "    from IPython.display import display\n",
        "except ImportError:\n",
        "\n",
        "    def display(obj):\n",
        "        print(obj)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "3f7f99d8",
      "metadata": {},
      "source": [
        "## 1. Configuration\n",
        "\n",
        "Line these knobs up with what you're using in the GNN notebook—especially **W**, **H**, decision step, and split fractions—or you're not comparing apples to apples."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "00caebbf",
      "metadata": {},
      "outputs": [],
      "source": [
        "@dataclass\n",
        "class Config:\n",
        "    \"\"\"Paths, columns, time windows, split fractions — defaults match my TGNN debug setup.\"\"\"\n",
        "\n",
        "    auth_path: str = \"../project/data/auth.txt.gz\"\n",
        "    redteam_path: str = \"../project/data/redteam.txt.gz\"\n",
        "    artifacts_dir: str = \"./artifacts\"\n",
        "    figures_dir: str = \"./figures\"\n",
        "    events_cache_path: str = \"./artifacts/events_df.parquet\"\n",
        "    dataset_cache_path: Optional[str] = None\n",
        "\n",
        "    col_time: str = \"time\"\n",
        "    col_src_host: str = \"src_computer\"\n",
        "    col_dst_host: str = \"dst_computer\"\n",
        "    col_success: str = \"success\"\n",
        "    col_is_malicious: str = \"is_malicious\"\n",
        "\n",
        "    sample_nrows: Optional[int] = 300_000\n",
        "    focus_span_sec: int = 3 * 86400\n",
        "    load_chunksize: int = 1_000_000\n",
        "\n",
        "    history_window_sec: int = 10 * 60\n",
        "    forecast_horizon_sec: int = 5 * 60\n",
        "    decision_interval_sec: int = 5 * 60\n",
        "\n",
        "    train_frac: float = 0.6\n",
        "    val_frac: float = 0.2\n",
        "\n",
        "    force_rebuild_dataset: bool = False\n",
        "    seed: int = 42\n",
        "\n",
        "    def __post_init__(self) -> None:\n",
        "        os.makedirs(self.artifacts_dir, exist_ok=True)\n",
        "        os.makedirs(self.figures_dir, exist_ok=True)\n",
        "        if self.dataset_cache_path is None:\n",
        "            self.dataset_cache_path = os.path.join(\n",
        "                self.artifacts_dir,\n",
        "                f\"baseline_dataset__W{self.history_window_sec}\"\n",
        "                f\"_H{self.forecast_horizon_sec}\"\n",
        "                f\"_step{self.decision_interval_sec}\"\n",
        "                f\"_nrows{self.sample_nrows}.parquet\",\n",
        "            )\n",
        "\n",
        "\n",
        "FEATURE_COLS: List[str] = [\n",
        "    \"roll_auth_count\",\n",
        "    \"roll_success_count\",\n",
        "    \"roll_failure_count\",\n",
        "    \"roll_fail_ratio\",\n",
        "    \"roll_out_degree\",\n",
        "    \"roll_in_degree\",\n",
        "    \"n_unique_counterparts\",\n",
        "    \"time_since_last_event\",\n",
        "    \"mean_inter_event_time\",\n",
        "    \"std_inter_event_time\",\n",
        "    \"hour_of_day\",\n",
        "    \"day_index\",\n",
        "]\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "18fb372d",
      "metadata": {},
      "source": [
        "## 2. Loading events\n",
        "\n",
        "Cached parquet at `events_cache_path` wins—otherwise we stream `auth.txt.gz`, trim to a red-team–anchored window like in the main notebook, and label rows that match red-team tuples as `is_malicious`."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "3e718323",
      "metadata": {},
      "outputs": [],
      "source": [
        "AUTH_COLS = [\n",
        "    \"time\", \"src_user\", \"dst_user\", \"src_computer\", \"dst_computer\",\n",
        "    \"auth_type\", \"logon_type\", \"auth_orient\", \"success\",\n",
        "]\n",
        "REDTEAM_COLS = [\"time\", \"user\", \"src_computer\", \"dst_computer\"]\n",
        "\n",
        "\n",
        "def _load_auth_focus_window(cfg: Config, t_lo: int, t_hi: int) -> pd.DataFrame:\n",
        "    \"\"\"Stream gzip auth; keep rows whose time falls in [t_lo, t_hi], stop at sample_nrows.\"\"\"\n",
        "    pieces: List[pd.DataFrame] = []\n",
        "    kept = 0\n",
        "    reader = pd.read_csv(\n",
        "        cfg.auth_path,\n",
        "        compression=\"gzip\",\n",
        "        header=None,\n",
        "        names=AUTH_COLS,\n",
        "        na_values=[\"?\"],\n",
        "        chunksize=cfg.load_chunksize,\n",
        "        low_memory=False,\n",
        "    )\n",
        "    for _, chunk in enumerate(reader):\n",
        "        t = chunk[\"time\"].astype(np.int64)\n",
        "        if t.iloc[0] > t_hi:\n",
        "            break\n",
        "        if t.iloc[-1] < t_lo:\n",
        "            continue\n",
        "        sub = chunk[(t >= t_lo) & (t <= t_hi)]\n",
        "        if len(sub):\n",
        "            pieces.append(sub)\n",
        "            kept += len(sub)\n",
        "        if cfg.sample_nrows is not None and kept >= cfg.sample_nrows:\n",
        "            break\n",
        "    if not pieces:\n",
        "        raise RuntimeError(\n",
        "            f\"No auth rows in [{t_lo}, {t_hi}] — check paths, focus_span_sec, or sample_nrows.\"\n",
        "        )\n",
        "    df = pd.concat(pieces, ignore_index=True)\n",
        "    if cfg.sample_nrows is not None and len(df) > cfg.sample_nrows:\n",
        "        df = df.iloc[: cfg.sample_nrows].copy()\n",
        "    return df\n",
        "\n",
        "\n",
        "def _attach_redteam_label(auth_df: pd.DataFrame, rt_df: pd.DataFrame) -> pd.DataFrame:\n",
        "    rt = rt_df.dropna().copy()\n",
        "    rt[\"time\"] = rt[\"time\"].astype(np.int64)\n",
        "    rt = rt.rename(columns={\"user\": \"src_user\"})\n",
        "    keys = [\"time\", \"src_user\", \"src_computer\", \"dst_computer\"]\n",
        "    merged = auth_df.merge(\n",
        "        rt[keys].drop_duplicates(), on=keys, how=\"left\", indicator=True\n",
        "    )\n",
        "    out = auth_df.copy()\n",
        "    out[\"is_malicious\"] = (merged[\"_merge\"] == \"both\").to_numpy()\n",
        "    return out\n",
        "\n",
        "\n",
        "def load_events(cfg: Config) -> pd.DataFrame:\n",
        "    if os.path.exists(cfg.events_cache_path):\n",
        "        print(f\"Using cached events: {cfg.events_cache_path}\")\n",
        "        df = pd.read_parquet(cfg.events_cache_path)\n",
        "    else:\n",
        "        print(\"No parquet cache — streaming auth + redteam...\")\n",
        "        rt_df = pd.read_csv(\n",
        "            cfg.redteam_path,\n",
        "            compression=\"gzip\",\n",
        "            header=None,\n",
        "            names=REDTEAM_COLS,\n",
        "            na_values=[\"?\"],\n",
        "            low_memory=False,\n",
        "        )\n",
        "        rt_df[\"time\"] = rt_df[\"time\"].astype(np.int64)\n",
        "        rt_t_min = int(rt_df[\"time\"].min())\n",
        "        t_lo = rt_t_min - cfg.history_window_sec\n",
        "        t_hi = t_lo + cfg.focus_span_sec\n",
        "        print(f\"  red-team t range: {rt_t_min} -> {int(rt_df['time'].max())}\")\n",
        "        print(f\"  loading auth window [{t_lo}, {t_hi}] (cap {cfg.sample_nrows})\")\n",
        "        auth_df = _load_auth_focus_window(cfg, t_lo, t_hi)\n",
        "        auth_df = auth_df.dropna(\n",
        "            subset=[cfg.col_time, cfg.col_src_host, cfg.col_dst_host]\n",
        "        ).copy()\n",
        "        auth_df[cfg.col_time] = auth_df[cfg.col_time].astype(np.int64)\n",
        "        auth_df = auth_df.sort_values(cfg.col_time, kind=\"mergesort\").reset_index(drop=True)\n",
        "        auth_df = _attach_redteam_label(auth_df, rt_df)\n",
        "        df = auth_df[\n",
        "            [\n",
        "                cfg.col_time,\n",
        "                cfg.col_src_host,\n",
        "                cfg.col_dst_host,\n",
        "                cfg.col_success,\n",
        "                cfg.col_is_malicious,\n",
        "            ]\n",
        "        ].copy()\n",
        "        df.to_parquet(cfg.events_cache_path, index=False)\n",
        "        print(f\"Saved events to {cfg.events_cache_path}\")\n",
        "\n",
        "    df = df.sort_values(cfg.col_time, kind=\"mergesort\").reset_index(drop=True)\n",
        "    print(\n",
        "        f\"Loaded {len(df):,} events | \"\n",
        "        f\"time {int(df[cfg.col_time].min())}–{int(df[cfg.col_time].max())} | \"\n",
        "        f\"{int(df[cfg.col_is_malicious].sum())} malicious\"\n",
        "    )\n",
        "    return df\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "71982f82",
      "metadata": {},
      "source": [
        "## 3. Decision grid and host index\n",
        "\n",
        "Decision times run from `T_MIN + W` up to `T_MAX - H` on your step size—same construction as the graph model. Events are grouped per host in time order so slicing `(t-W, t]` is cheap."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "8dfe08c8",
      "metadata": {},
      "outputs": [],
      "source": [
        "def make_decision_grid(events_df: pd.DataFrame, cfg: Config) -> np.ndarray:\n",
        "    t_min = int(events_df[cfg.col_time].min())\n",
        "    t_max = int(events_df[cfg.col_time].max())\n",
        "    dec_start = t_min + cfg.history_window_sec\n",
        "    dec_end = t_max - cfg.forecast_horizon_sec\n",
        "    grid = np.arange(dec_start, dec_end + 1, cfg.decision_interval_sec, dtype=np.int64)\n",
        "    if len(grid) < 3:\n",
        "        raise RuntimeError(\n",
        "            f\"Not enough decision times ({len(grid)}). Shorten W/H or load more data.\"\n",
        "        )\n",
        "    print(\n",
        "                f\"{len(grid)} decision times every {cfg.decision_interval_sec}s \"\n",
        "        f\"(W={cfg.history_window_sec}s, H={cfg.forecast_horizon_sec}s)\"\n",
        "    )\n",
        "    return grid\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class HostIndex:\n",
        "    t: np.ndarray\n",
        "    is_src: np.ndarray\n",
        "    success: np.ndarray\n",
        "    counterpart: np.ndarray\n",
        "    t_mal: np.ndarray\n",
        "\n",
        "\n",
        "def build_host_index(\n",
        "    events_df: pd.DataFrame, cfg: Config\n",
        ") -> Tuple[List[str], Dict[int, HostIndex]]:\n",
        "    src = events_df[cfg.col_src_host].astype(str).to_numpy()\n",
        "    dst = events_df[cfg.col_dst_host].astype(str).to_numpy()\n",
        "    t_arr = events_df[cfg.col_time].to_numpy(dtype=np.int64)\n",
        "    success = (\n",
        "        events_df[cfg.col_success].astype(str).str.lower().eq(\"success\").to_numpy()\n",
        "    )\n",
        "    is_mal = events_df[cfg.col_is_malicious].astype(bool).to_numpy()\n",
        "\n",
        "    all_hosts = np.unique(np.concatenate([src, dst]))\n",
        "    host2id = {h: i for i, h in enumerate(all_hosts)}\n",
        "    host_list = list(all_hosts)\n",
        "    src_id = np.fromiter((host2id[h] for h in src), count=len(src), dtype=np.int64)\n",
        "    dst_id = np.fromiter((host2id[h] for h in dst), count=len(dst), dtype=np.int64)\n",
        "\n",
        "    n = len(events_df)\n",
        "    host_long = np.concatenate([src_id, dst_id])\n",
        "    t_long = np.concatenate([t_arr, t_arr])\n",
        "    is_src_long = np.concatenate([np.ones(n, dtype=bool), np.zeros(n, dtype=bool)])\n",
        "    success_long = np.concatenate([success, success])\n",
        "    counterpart_long = np.concatenate([dst_id, src_id])\n",
        "    mal_long = np.concatenate([is_mal, is_mal])\n",
        "\n",
        "    order = np.lexsort((t_long, host_long))\n",
        "    host_long = host_long[order]\n",
        "    t_long = t_long[order]\n",
        "    is_src_long = is_src_long[order]\n",
        "    success_long = success_long[order]\n",
        "    counterpart_long = counterpart_long[order]\n",
        "    mal_long = mal_long[order]\n",
        "\n",
        "    boundaries = np.concatenate(\n",
        "        ([0], np.flatnonzero(np.diff(host_long)) + 1, [len(host_long)])\n",
        "    )\n",
        "\n",
        "    host_index: Dict[int, HostIndex] = {}\n",
        "    for k in range(len(boundaries) - 1):\n",
        "        lo, hi = boundaries[k], boundaries[k + 1]\n",
        "        h = int(host_long[lo])\n",
        "        ts = t_long[lo:hi]\n",
        "        host_index[h] = HostIndex(\n",
        "            t=ts,\n",
        "            is_src=is_src_long[lo:hi],\n",
        "            success=success_long[lo:hi],\n",
        "            counterpart=counterpart_long[lo:hi],\n",
        "            t_mal=ts[mal_long[lo:hi]],\n",
        "        )\n",
        "\n",
        "    print(f\"Indexed {len(host_list)} hosts\")\n",
        "    return host_list, host_index\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "0ad7c4fc",
      "metadata": {},
      "source": [
        "## 4. Features and labels\n",
        "\n",
        "Everything in the feature vector comes from **(t−W, t]** only. The label is 1 if that host hits at least one malicious row in **(t, t+H]** (either endpoint); otherwise 0."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "9721ad40",
      "metadata": {},
      "outputs": [],
      "source": [
        "def compute_host_features(\n",
        "    hi: HostIndex, t: int, w: int, t0_for_day: int\n",
        ") -> Optional[Dict[str, float]]:\n",
        "    lo = t - w\n",
        "    i_lo = np.searchsorted(hi.t, lo, side=\"right\")\n",
        "    i_hi = np.searchsorted(hi.t, t, side=\"right\")\n",
        "    if i_hi <= i_lo:\n",
        "        return None\n",
        "\n",
        "    t_win = hi.t[i_lo:i_hi]\n",
        "    is_src_win = hi.is_src[i_lo:i_hi]\n",
        "    success_win = hi.success[i_lo:i_hi]\n",
        "    counterpart_win = hi.counterpart[i_lo:i_hi]\n",
        "\n",
        "    n = int(t_win.size)\n",
        "    n_success = int(success_win.sum())\n",
        "    n_failure = n - n_success\n",
        "    n_out = int(is_src_win.sum())\n",
        "    n_in = n - n_out\n",
        "    fail_ratio = n_failure / n if n > 0 else 0.0\n",
        "    n_uniq_counterparts = int(np.unique(counterpart_win).size)\n",
        "    time_since_last = float(t - int(t_win[-1]))\n",
        "\n",
        "    if n >= 2:\n",
        "        d = np.diff(t_win)\n",
        "        mean_iet = float(np.mean(d))\n",
        "        std_iet = float(np.std(d))\n",
        "    else:\n",
        "        mean_iet = np.nan\n",
        "        std_iet = np.nan\n",
        "\n",
        "    hour_of_day = int((t // 3600) % 24)\n",
        "    day_index = int((t - t0_for_day) // 86400)\n",
        "\n",
        "    return {\n",
        "        \"roll_auth_count\": float(n),\n",
        "        \"roll_success_count\": float(n_success),\n",
        "        \"roll_failure_count\": float(n_failure),\n",
        "        \"roll_fail_ratio\": float(fail_ratio),\n",
        "        \"roll_out_degree\": float(n_out),\n",
        "        \"roll_in_degree\": float(n_in),\n",
        "        \"n_unique_counterparts\": float(n_uniq_counterparts),\n",
        "        \"time_since_last_event\": time_since_last,\n",
        "        \"mean_inter_event_time\": mean_iet,\n",
        "        \"std_inter_event_time\": std_iet,\n",
        "        \"hour_of_day\": float(hour_of_day),\n",
        "        \"day_index\": float(day_index),\n",
        "    }\n",
        "\n",
        "\n",
        "def host_label_at(hi: HostIndex, t: int, h_sec: int) -> int:\n",
        "    if hi.t_mal.size == 0:\n",
        "        return 0\n",
        "    j_lo = np.searchsorted(hi.t_mal, t, side=\"right\")\n",
        "    j_hi = np.searchsorted(hi.t_mal, t + h_sec, side=\"right\")\n",
        "    return int(j_hi > j_lo)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "ce0d9d5a",
      "metadata": {},
      "source": [
        "## 5. Build the table\n",
        "\n",
        "The full host×decision-time matrix gets written to `dataset_cache_path` unless you set `force_rebuild_dataset=True` to force a rebuild."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cacc9fd2",
      "metadata": {},
      "outputs": [],
      "source": [
        "def build_dataset(events_df: pd.DataFrame, cfg: Config) -> pd.DataFrame:\n",
        "    cache_path = cfg.dataset_cache_path\n",
        "    if cache_path and os.path.exists(cache_path) and not cfg.force_rebuild_dataset:\n",
        "        print(f\"Reading cached dataset from {cache_path}\")\n",
        "        return pd.read_parquet(cache_path)\n",
        "\n",
        "    decision_times = make_decision_grid(events_df, cfg)\n",
        "    host_list, host_index = build_host_index(events_df, cfg)\n",
        "    t0_for_day = int(events_df[cfg.col_time].min())\n",
        "\n",
        "    rows: List[Dict[str, float]] = []\n",
        "    for t in tqdm(decision_times, desc=\"build_dataset\", unit=\"dt\"):\n",
        "        t_int = int(t)\n",
        "        for h_id, hi in host_index.items():\n",
        "            feats = compute_host_features(hi, t_int, cfg.history_window_sec, t0_for_day)\n",
        "            if feats is None:\n",
        "                continue\n",
        "            label = host_label_at(hi, t_int, cfg.forecast_horizon_sec)\n",
        "            rows.append(\n",
        "                {\n",
        "                    \"decision_time\": t_int,\n",
        "                    \"host_id\": h_id,\n",
        "                    \"host\": host_list[h_id],\n",
        "                    \"label\": int(label),\n",
        "                    **feats,\n",
        "                }\n",
        "            )\n",
        "\n",
        "    df = pd.DataFrame(rows)\n",
        "    if df.empty:\n",
        "        raise RuntimeError(\"Empty dataset — loosen W, H, or decision_interval_sec.\")\n",
        "    if cache_path:\n",
        "        df.to_parquet(cache_path, index=False)\n",
        "        print(f\"Wrote dataset cache to {cache_path}\")\n",
        "    print(\n",
        "                f\"{len(df):,} rows, {int(df['label'].sum())} positive, \"\n",
        "        f\"{df['decision_time'].nunique()} distinct decision times\"\n",
        "    )\n",
        "    return df\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "d16b279c",
      "metadata": {},
      "source": [
        "## 6. Train / val / test by time\n",
        "\n",
        "Splits use **decision_time** cutoffs—here 60% / 20% / 20% of the span between earliest and latest decision time. No row-level shuffle.\n",
        "\n",
        "If you only get a handful of decision times (easy on a tiny subsample), the middle bucket can end up **empty**—then sklearn would choke on zero validation rows. The training cell skips scoring an empty matrix, fills val metrics with NaN, and falls back to threshold 0.5 for the `@val_thr` columns. Usually loading more data or tightening `decision_interval_sec` fixes it."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "9c38dc91",
      "metadata": {},
      "outputs": [],
      "source": [
        "def chronological_split(\n",
        "    df: pd.DataFrame, cfg: Config\n",
        ") -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, Dict[str, int]]:\n",
        "    t_min = int(df[\"decision_time\"].min())\n",
        "    t_max = int(df[\"decision_time\"].max())\n",
        "    t_range = t_max - t_min\n",
        "    train_end_t = int(t_min + cfg.train_frac * t_range)\n",
        "    val_end_t = int(t_min + (cfg.train_frac + cfg.val_frac) * t_range)\n",
        "\n",
        "    df = df.copy()\n",
        "    df[\"split\"] = \"train\"\n",
        "    df.loc[df[\"decision_time\"] > train_end_t, \"split\"] = \"val\"\n",
        "    df.loc[df[\"decision_time\"] > val_end_t, \"split\"] = \"test\"\n",
        "\n",
        "    splits = {\"train_end_t\": train_end_t, \"val_end_t\": val_end_t, \"t_min\": t_min, \"t_max\": t_max}\n",
        "    train_df = df[df[\"split\"] == \"train\"].copy()\n",
        "    val_df = df[df[\"split\"] == \"val\"].copy()\n",
        "    test_df = df[df[\"split\"] == \"test\"].copy()\n",
        "    print(\n",
        "                f\"train {len(train_df)} ({int(train_df['label'].sum())} pos) | \"\n",
        "        f\"val {len(val_df)} ({int(val_df['label'].sum())} pos) | \"\n",
        "        f\"test {len(test_df)} ({int(test_df['label'].sum())} pos) | \"\n",
        "        f\"cutoffs {train_end_t} / {val_end_t} (s)\"\n",
        "    )\n",
        "    return train_df, val_df, test_df, splits\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "f636c7e7",
      "metadata": {},
      "source": [
        "## 7. Models\n",
        "\n",
        "Logistic regression goes through `SimpleImputer` → `StandardScaler` → `LogisticRegression`; fit always happens on **train** rows only. Histogram gradient boosting sees the raw numeric matrix—it's fine with NaNs and doesn't need scaling."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "69ceb672",
      "metadata": {},
      "outputs": [],
      "source": [
        "def make_logistic_regression(seed: int) -> Pipeline:\n",
        "    return Pipeline(\n",
        "        [\n",
        "            (\"imputer\", SimpleImputer(strategy=\"constant\", fill_value=0.0)),\n",
        "            (\"scaler\", StandardScaler()),\n",
        "            (\n",
        "                \"lr\",\n",
        "                LogisticRegression(\n",
        "                    class_weight=\"balanced\",\n",
        "                    max_iter=2000,\n",
        "                    solver=\"lbfgs\",\n",
        "                    random_state=seed,\n",
        "                ),\n",
        "            ),\n",
        "        ]\n",
        "    )\n",
        "\n",
        "\n",
        "def make_hist_gbm(seed: int) -> HistGradientBoostingClassifier:\n",
        "    return HistGradientBoostingClassifier(random_state=seed)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "4cba242f",
      "metadata": {},
      "source": [
        "## 8. Metrics and plots\n",
        "\n",
        "AUROC / AP, precision-recall-F1 at 0.5, another block at the threshold tuned on val (when val isn't empty), plus ROC and PR figures saved under `figures_dir`."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "0213e451",
      "metadata": {},
      "outputs": [],
      "source": [
        "def _safe_auroc(y_true: np.ndarray, scores: np.ndarray) -> float:\n",
        "    if y_true.size == 0 or y_true.sum() == 0 or y_true.sum() == y_true.size:\n",
        "        return float(\"nan\")\n",
        "    return float(roc_auc_score(y_true, scores))\n",
        "\n",
        "\n",
        "def _safe_ap(y_true: np.ndarray, scores: np.ndarray) -> float:\n",
        "    if y_true.size == 0 or y_true.sum() == 0:\n",
        "        return float(\"nan\")\n",
        "    return float(average_precision_score(y_true, scores))\n",
        "\n",
        "\n",
        "def metrics_at_threshold(\n",
        "    y_true: np.ndarray, scores: np.ndarray, threshold: float\n",
        ") -> Dict[str, float]:\n",
        "    \"\"\"PRF1 + confusion counts at one cutoff on the score scale.\"\"\"\n",
        "    if y_true.size == 0:\n",
        "        return {\n",
        "            \"precision\": float(\"nan\"),\n",
        "            \"recall\": float(\"nan\"),\n",
        "            \"f1\": float(\"nan\"),\n",
        "            \"tn\": 0, \"fp\": 0, \"fn\": 0, \"tp\": 0,\n",
        "        }\n",
        "    y_pred = (scores >= threshold).astype(int)\n",
        "    if y_true.sum() == 0 and y_pred.sum() == 0:\n",
        "        p = r = f1 = 0.0\n",
        "    else:\n",
        "        p, r, f1, _ = precision_recall_fscore_support(\n",
        "            y_true, y_pred, average=\"binary\", zero_division=0\n",
        "        )\n",
        "    cm = confusion_matrix(y_true, y_pred, labels=[0, 1])\n",
        "    return {\n",
        "        \"precision\": float(p),\n",
        "        \"recall\": float(r),\n",
        "        \"f1\": float(f1),\n",
        "        \"tn\": int(cm[0, 0]), \"fp\": int(cm[0, 1]),\n",
        "        \"fn\": int(cm[1, 0]), \"tp\": int(cm[1, 1]),\n",
        "    }\n",
        "\n",
        "\n",
        "def best_val_threshold(y_true: np.ndarray, scores: np.ndarray) -> float:\n",
        "    \"\"\"Threshold that maximizes F1 on val scores (0.5 if val is empty).\"\"\"\n",
        "    if y_true.sum() == 0 or y_true.size == 0:\n",
        "        return 0.5\n",
        "    pr, rc, th = precision_recall_curve(y_true, scores)\n",
        "    # sklearn drops the last point so lengths line up with `th`\n",
        "    f1 = 2 * pr[:-1] * rc[:-1] / np.maximum(pr[:-1] + rc[:-1], 1e-12)\n",
        "    if f1.size == 0:\n",
        "        return 0.5\n",
        "    best = int(np.argmax(f1))\n",
        "    return float(th[best])\n",
        "\n",
        "\n",
        "def evaluate_scores(\n",
        "    y_true: np.ndarray, scores: np.ndarray, fixed_threshold: float = 0.5,\n",
        "    val_threshold: Optional[float] = None,\n",
        ") -> Dict[str, float]:\n",
        "    \"\"\"Package AUROC/AP plus metrics at 0.5 and optionally at a tuned threshold.\"\"\"\n",
        "    nan = float(\"nan\")\n",
        "    if y_true.size == 0:\n",
        "        # Empty val or test slice after the time-based split\n",
        "        out: Dict[str, float] = {\n",
        "            \"auroc\": nan,\n",
        "            \"ap\": nan,\n",
        "            \"precision@0.5\": nan,\n",
        "            \"recall@0.5\": nan,\n",
        "            \"f1@0.5\": nan,\n",
        "            \"tn@0.5\": nan,\n",
        "            \"fp@0.5\": nan,\n",
        "            \"fn@0.5\": nan,\n",
        "            \"tp@0.5\": nan,\n",
        "        }\n",
        "        if val_threshold is not None:\n",
        "            out[\"val_threshold\"] = float(val_threshold)\n",
        "            out.update({\n",
        "                \"precision@val_thr\": nan,\n",
        "                \"recall@val_thr\": nan,\n",
        "                \"f1@val_thr\": nan,\n",
        "                \"tn@val_thr\": nan,\n",
        "                \"fp@val_thr\": nan,\n",
        "                \"fn@val_thr\": nan,\n",
        "                \"tp@val_thr\": nan,\n",
        "            })\n",
        "        return out\n",
        "\n",
        "    out = {\n",
        "        \"auroc\": _safe_auroc(y_true, scores),\n",
        "        \"ap\": _safe_ap(y_true, scores),\n",
        "    }\n",
        "    out.update({f\"{k}@0.5\": v for k, v in\n",
        "                metrics_at_threshold(y_true, scores, fixed_threshold).items()})\n",
        "    if val_threshold is not None:\n",
        "        out[\"val_threshold\"] = float(val_threshold)\n",
        "        out.update({f\"{k}@val_thr\": v for k, v in\n",
        "                    metrics_at_threshold(y_true, scores, val_threshold).items()})\n",
        "    return out\n",
        "\n",
        "\n",
        "def plot_curves(\n",
        "    results: Dict[str, Dict[str, np.ndarray]],\n",
        "    cfg: Config,\n",
        "    split_name: str,\n",
        ") -> None:\n",
        "    \"\"\"Save ROC + PR overlay plots for val or test.\"\"\"\n",
        "    fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
        "    for name, payload in results.items():\n",
        "        y, s = payload[f\"{split_name}_y\"], payload[f\"{split_name}_scores\"]\n",
        "        if y.size == 0 or y.sum() == 0 or y.sum() == y.size:\n",
        "            continue\n",
        "        fpr, tpr, _ = roc_curve(y, s)\n",
        "        axes[0].plot(fpr, tpr, label=f\"{name} (AUROC={_safe_auroc(y, s):.3f})\")\n",
        "        pr, rc, _ = precision_recall_curve(y, s)\n",
        "        axes[1].plot(rc, pr, label=f\"{name} (AP={_safe_ap(y, s):.3f})\")\n",
        "    axes[0].plot([0, 1], [0, 1], \"--\", color=\"gray\", lw=0.8)\n",
        "    axes[0].set_xlabel(\"False positive rate\")\n",
        "    axes[0].set_ylabel(\"True positive rate\")\n",
        "    axes[0].set_title(f\"ROC ({split_name})\")\n",
        "    axes[0].legend()\n",
        "    axes[1].set_xlabel(\"Recall\")\n",
        "    axes[1].set_ylabel(\"Precision\")\n",
        "    axes[1].set_title(f\"Precision–recall ({split_name})\")\n",
        "    axes[1].legend()\n",
        "    plt.tight_layout()\n",
        "    out = os.path.join(cfg.figures_dir, f\"baselines_curves_{split_name}.png\")\n",
        "    plt.savefig(out, dpi=120)\n",
        "    plt.close(fig)\n",
        "    print(f\"Saved figure {out}\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "dbbe5b34",
      "metadata": {},
      "source": [
        "## 9. Train everything\n",
        "\n",
        "Two fitted models plus a dumb baseline that ranks hosts only by **`roll_failure_count`** in the history window—mostly there as a sanity check that learning beats counting failures."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "97b8899d",
      "metadata": {},
      "outputs": [],
      "source": [
        "def train_baselines(\n",
        "    train_df: pd.DataFrame,\n",
        "    val_df: pd.DataFrame,\n",
        "    test_df: pd.DataFrame,\n",
        "    feature_cols: List[str],\n",
        "    cfg: Config,\n",
        ") -> Dict[str, Dict]:\n",
        "    \"\"\"Train LR + gradient boosting, score val/test; heuristic needs no fit.\"\"\"\n",
        "    X_train = train_df[feature_cols].to_numpy(dtype=np.float64)\n",
        "    y_train = train_df[\"label\"].to_numpy(dtype=np.int64)\n",
        "    X_val = val_df[feature_cols].to_numpy(dtype=np.float64)\n",
        "    y_val = val_df[\"label\"].to_numpy(dtype=np.int64)\n",
        "    X_test = test_df[feature_cols].to_numpy(dtype=np.float64)\n",
        "    y_test = test_df[\"label\"].to_numpy(dtype=np.int64)\n",
        "\n",
        "    n_val, n_test = int(X_val.shape[0]), int(X_test.shape[0])\n",
        "    if n_val == 0:\n",
        "        print(\n",
        "            \"Heads up: validation is empty — with this sample there aren't enough \"\n",
        "            \"decision times to fill the middle 20% bucket. Val scores stay NaN \"\n",
        "            \"and I default threshold-for-metrics to 0.5. Try more rows or a shorter \"\n",
        "            \"decision_interval_sec if you want a real val split.\"\n",
        "        )\n",
        "    if n_test == 0:\n",
        "        print(\n",
        "            \"Test split is empty too — test metrics will be NaN.\"\n",
        "        )\n",
        "\n",
        "    pos_train = int(y_train.sum())\n",
        "    print(f\"Training matrix {X_train.shape}, {pos_train} positives\")\n",
        "    if pos_train == 0:\n",
        "        print(\"No positive labels in train — models won't learn anything useful; \"\n",
        "              \"grab a slice that actually overlaps red-team activity.\")\n",
        "\n",
        "    results: Dict[str, Dict] = {}\n",
        "\n",
        "    def val_test_scores_predict_proba(model) -> Tuple[np.ndarray, np.ndarray, float]:\n",
        "        \"\"\"Avoid sklearn on empty val/test — imputer hates zero rows.\"\"\"\n",
        "        if n_val == 0:\n",
        "            val_s = np.array([], dtype=np.float64)\n",
        "            thr = 0.5\n",
        "        else:\n",
        "            val_s = model.predict_proba(X_val)[:, 1]\n",
        "            thr = best_val_threshold(y_val, val_s)\n",
        "        if n_test == 0:\n",
        "            test_s = np.array([], dtype=np.float64)\n",
        "        else:\n",
        "            test_s = model.predict_proba(X_test)[:, 1]\n",
        "        return val_s, test_s, thr\n",
        "\n",
        "    # Logistic regression\n",
        "    print(\"Fitting logistic regression...\")\n",
        "    t0 = time.perf_counter()\n",
        "    lr_pipe = make_logistic_regression(cfg.seed)\n",
        "    lr_pipe.fit(X_train, y_train)\n",
        "    lr_train_t = time.perf_counter() - t0\n",
        "    val_scores, test_scores, val_thr = val_test_scores_predict_proba(lr_pipe)\n",
        "    results[\"logreg\"] = {\n",
        "        \"val\": evaluate_scores(y_val, val_scores, val_threshold=val_thr),\n",
        "        \"test\": evaluate_scores(y_test, test_scores, val_threshold=val_thr),\n",
        "        \"val_y\": y_val, \"val_scores\": val_scores,\n",
        "        \"test_y\": y_test, \"test_scores\": test_scores,\n",
        "        \"fit_time_s\": lr_train_t,\n",
        "        \"model\": lr_pipe,\n",
        "    }\n",
        "\n",
        "    # Histogram gradient boosting\n",
        "    print(\"Fitting histogram gradient boosting...\")\n",
        "    t0 = time.perf_counter()\n",
        "    gbm = make_hist_gbm(cfg.seed)\n",
        "    gbm.fit(X_train, y_train)\n",
        "    gbm_train_t = time.perf_counter() - t0\n",
        "    val_scores, test_scores, val_thr = val_test_scores_predict_proba(gbm)\n",
        "    results[\"hist_gbm\"] = {\n",
        "        \"val\": evaluate_scores(y_val, val_scores, val_threshold=val_thr),\n",
        "        \"test\": evaluate_scores(y_test, test_scores, val_threshold=val_thr),\n",
        "        \"val_y\": y_val, \"val_scores\": val_scores,\n",
        "        \"test_y\": y_test, \"test_scores\": test_scores,\n",
        "        \"fit_time_s\": gbm_train_t,\n",
        "        \"model\": gbm,\n",
        "    }\n",
        "\n",
        "    # Failure-count baseline (no training)\n",
        "    fail_idx = feature_cols.index(\"roll_failure_count\")\n",
        "    if n_val == 0:\n",
        "        val_scores = np.array([], dtype=np.float64)\n",
        "        val_thr = 0.5\n",
        "    else:\n",
        "        val_scores = X_val[:, fail_idx]\n",
        "        val_thr = best_val_threshold(y_val, val_scores)\n",
        "    if n_test == 0:\n",
        "        test_scores = np.array([], dtype=np.float64)\n",
        "    else:\n",
        "        test_scores = X_test[:, fail_idx]\n",
        "    results[\"recent_failures_heuristic\"] = {\n",
        "        \"val\": evaluate_scores(y_val, val_scores, val_threshold=val_thr),\n",
        "        \"test\": evaluate_scores(y_test, test_scores, val_threshold=val_thr),\n",
        "        \"val_y\": y_val, \"val_scores\": val_scores,\n",
        "        \"test_y\": y_test, \"test_scores\": test_scores,\n",
        "        \"fit_time_s\": 0.0,\n",
        "        \"model\": None,\n",
        "    }\n",
        "\n",
        "    return results\n",
        "\n",
        "\n",
        "def summarize_results(results: Dict[str, Dict]) -> pd.DataFrame:\n",
        "    \"\"\"One row per model × split for CSV / pretty-printing.\"\"\"\n",
        "    rows = []\n",
        "    for name, payload in results.items():\n",
        "        for split in (\"val\", \"test\"):\n",
        "            d = {\"model\": name, \"split\": split, \"fit_time_s\": payload[\"fit_time_s\"]}\n",
        "            d.update(payload[split])\n",
        "            rows.append(d)\n",
        "    df = pd.DataFrame(rows)\n",
        "    cols = [\"model\", \"split\", \"auroc\", \"ap\",\n",
        "            \"precision@0.5\", \"recall@0.5\", \"f1@0.5\",\n",
        "            \"val_threshold\",\n",
        "            \"precision@val_thr\", \"recall@val_thr\", \"f1@val_thr\",\n",
        "            \"tp@val_thr\", \"fp@val_thr\", \"fn@val_thr\", \"tn@val_thr\",\n",
        "            \"fit_time_s\"]\n",
        "    cols = [c for c in cols if c in df.columns]\n",
        "    return df[cols]\n",
        "\n",
        "\n",
        "def export_lr_coefficients(\n",
        "    results: Dict[str, Dict], feature_cols: List[str], cfg: Config\n",
        ") -> None:\n",
        "    \"\"\"Dump logistic coefficients on the scaled features for a quick read.\"\"\"\n",
        "    pipe = results.get(\"logreg\", {}).get(\"model\")\n",
        "    if pipe is None:\n",
        "        return\n",
        "    lr = pipe.named_steps[\"lr\"]\n",
        "    coefs = lr.coef_.ravel()\n",
        "    out = pd.DataFrame({\n",
        "        \"feature\": feature_cols,\n",
        "        \"coef_standardized\": coefs,\n",
        "        \"abs_coef\": np.abs(coefs),\n",
        "    }).sort_values(\"abs_coef\", ascending=False)\n",
        "    path = os.path.join(cfg.artifacts_dir, \"baseline_logreg_coefficients.csv\")\n",
        "    out.to_csv(path, index=False)\n",
        "    print(f\"Wrote LR coefficients to {path}\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "ac38d5c6",
      "metadata": {},
      "source": [
        "## 10. Run it\n",
        "\n",
        "Execute the cell below (after tweaking `Config` if you want). You'll get `baseline_results.csv`, ROC/PR PNGs in `figures_dir`, and logistic coefficients in `artifacts_dir`."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "c99f3483",
      "metadata": {},
      "outputs": [],
      "source": [
        "cfg = Config()\n",
        "np.random.seed(cfg.seed)\n",
        "print(\"Current config:\")\n",
        "print(json.dumps(asdict(cfg), indent=2, default=str))\n",
        "\n",
        "events_df = load_events(cfg)\n",
        "dataset = build_dataset(events_df, cfg)\n",
        "train_df, val_df, test_df, _ = chronological_split(dataset, cfg)\n",
        "results = train_baselines(train_df, val_df, test_df, FEATURE_COLS, cfg)\n",
        "\n",
        "summary = summarize_results(results)\n",
        "print()\n",
        "print(\"Results (val / test):\")\n",
        "with pd.option_context(\n",
        "    \"display.max_columns\", None,\n",
        "    \"display.width\", 220,\n",
        "    \"display.float_format\", \"{:.4f}\".format,\n",
        "):\n",
        "    display(summary)\n",
        "\n",
        "summary_path = os.path.join(cfg.artifacts_dir, \"baseline_results.csv\")\n",
        "summary.to_csv(summary_path, index=False)\n",
        "print(f\"\\nSaved summary table to {summary_path}\")\n",
        "\n",
        "plot_curves(results, cfg, split_name=\"val\")\n",
        "plot_curves(results, cfg, split_name=\"test\")\n",
        "export_lr_coefficients(results, FEATURE_COLS, cfg)\n"
      ]
    }
  ],
